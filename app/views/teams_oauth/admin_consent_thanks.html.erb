<!-- app/views/invites/show.html.erb -->
<div class="onboarding-bg"></div>

<div class="onboarding-content">
    <div class="info-card-images">
      <div class="info-card-icon" style="background-image: url('<%= image_path("apps/workplace.png") %>')"></div>

      <div class="info-card-icon-connect">
        <div class="info-card-icon-connect-dot-small"></div>
        <div class="info-card-icon-connect-dot-large"></div>
        <div class="info-card-icon-connect-dot-small"></div>
      </div>

      <div
        class="info-card-icon"
        style="background-image: url('<%= image_path("apps/microsoft_teams.png") %>')">
      </div>
    </div>

    <% if @status == :ok && @consented %>

      <div class="info-card-header">
         Workplace.io is now approved
      </div>

      <div class="info-card-content">

        <div class="info-card-row">
          <div class="info-card-row-value">
            Thank you — Workplace.io now has permission to connect to your organization’s
            Microsoft 365 tenant (<code><%= @tenant_id %></code>).
          </div>
        </div>

        <div class="info-card-row">
          <div class="info-card-row-value">
            You can close this window. The person who requested the integration
            can now return to Workplace.io and click “Connect Microsoft Teams”
            to finish setup.
          </div>
        </div>

      <% else %>
        <div class="info-card-header">
           We could not confirm approval
        </div>

        <div class="info-card-content">
          <div class="info-card-row">
            <div class="info-card-row-value">
              Something went wrong while trying to approve Workplace.io. Please try
              the link again or contact support@workplace.io.
            </div>
          </div>
        </div>
      <% end %>

    </div>
</div>
