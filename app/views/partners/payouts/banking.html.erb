<h1>Banking & Tax Settings</h1>

<% if @trolley_widget_url.present? %>
  <iframe
    id="trolley-widget"
    title="Trolley Widget"
    src="<%= @trolley_widget_url %>"
    style="width:100%;height:100%;border:0;overflow:hidden;"
    allowtransparency="true"
    loading="eager"
    referrerpolicy="no-referrer">
  </iframe>
<% else %>
  <p class="text-muted">Widget unavailable. Please refresh.</p>
<% end %>

<script>
  // Optional auto-resize & success hooks
  window.addEventListener("message", function(e){
    var d = e.data || {};
    var f = document.getElementById("trolley-widget");
    if (!f) return;
    if (d.event === "document.height" && d.document && d.document.height) {
      f.style.height = d.document.height;
    } else if (d.event === "module.successful") {
      console.log("Trolley module completed:", d.module && d.module[0]);
      // e.g. refresh balances or show a notice
    }
  }, false);
</script>
