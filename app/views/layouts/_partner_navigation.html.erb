<% if user_signed_in? && current_user.partner? %>
  <div class="navigation">
    <div class="navigation-top">
      <div class="navigation-workspace-button">
        <div class="navigation-workspace-button-icon">P</div>
        <div class="navigation-workspace-button-name">Partner dashboard</div>
        <%= icon "chevron-down", class_name: "navigation-workspace-button-chevron" %>
      </div>

      <%= icon "sidebar", class_name: "navigation-toggle" %>
    </div>

    <%= link_to partner_dashboard_path, class: 'navigation-link' do %>
      <%= icon "home", class_name: "navigation-icon" %>
      <span>Overview</span>
    <% end %>

    <%= link_to partners_links_path, class: 'navigation-link' do %>
      <%= icon "link", class_name: "navigation-icon" %>
      <span>Links</span>
    <% end %>

    <%= link_to partners_leads_path, class: 'navigation-link' do %>
      <%= icon "user", class_name: "navigation-icon" %>
      <span>Leads</span>
    <% end %>

    <%= link_to partners_transactions_path, class: 'navigation-link' do %>
      <%= icon "card", class_name: "navigation-icon" %>
      <span>Transactions</span>
    <% end %>

    <%= link_to partners_payouts_path, class: 'navigation-link' do %>
      <%= icon "money", class_name: "navigation-icon" %>
      <span>Payouts</span>
    <% end %>

    <%= link_to banking_partners_payouts_path, class: "navigation-link" do %>
      <%= icon "bank", class_name: "navigation-icon" %>
      <span>Banking & Tax</span>
    <% end %>

    <%= link_to partners_analytics_path, class: 'navigation-link' do %>
      <%= icon "stat", class_name: "navigation-icon" %>
      <span>Analytics</span>
    <% end %>

    <%= link_to partners_resources_path, class: 'navigation-link' do %>
      <%= icon "doc", class_name: "navigation-icon" %>
      <span>Resources</span>
    <% end %>

    <% if masquerading? %>
      <%= button_to admin_stop_masquerade_path, method: :delete, class: "navigation-link", form_class: "navigation-inline-form" do %>
        <%= icon "left-arrow", class_name: "navigation-icon" %>
        <span>Return to Admin</span>
      <% end %>
    <% end %>

    <div class="navigation-footer">
      <%
        iu = current_user.integration_users
                         .detect { |x| x.integration&.workspace_id == @active_workspace&.id }
        avatar_url = iu&.avatar_url.presence
      %>

      <%= link_to edit_partners_profile_path, class: "navigation-link-footer" do %>
        <div class="navigation-footer-avatar"
             style="<%= "background-image: url('#{avatar_url}');" if avatar_url %>">
          <% unless avatar_url %>
            <%= icon "user" %>
          <% end %>
        </div>

        <div class="navigation-footer-meta">
          <div class="navigation-footer-name"><%= current_user.full_name %></div>
          <div class="navigation-footer-email"><%= current_user.email %></div>
        </div>

        <div class="navigation-footer-kebab">
          <%= icon "elipsis-vertical" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="navigation-top-dropdown">
    <div class="navigation-top-dropdown-heading">Workspaces</div>

    <%= link_to partner_dashboard_path,
                class: "navigation-top-dropdown-workspace navigation-top-dropdown-workspace--active" do %>
      <div class="navigation-top-dropdown-icon">P</div>
      <span class="navigation-top-dropdown-name">Partner dashboard</span>
    <% end %>

    <% available_workspaces.each do |workspace| %>
      <%
        ws_initials =
          workspace.name
            .to_s
            .split(/\s+/)
            .reject(&:blank?)
            .first(2)
            .map { |w| w[0] }
            .join
            .upcase
      %>

      <%= link_to switch_workspace_token_path(workspace.signed_id(purpose: "workspace_switch")),
                  method: :post,
                  class: "navigation-top-dropdown-workspace" do %>

        <div class="navigation-top-dropdown-icon js-workspace-nav-icon"
             data-workspace-token="<%= workspace.signed_id(purpose: 'workspace_switch') %>">
          <%= ws_initials %>
        </div>

        <span class="navigation-top-dropdown-name"><%= workspace.name %></span>
      <% end %>
    <% end %>

    <div class="navigation-top-dropdown-line"></div>

    <%= link_to edit_partners_profile_path, class: "navigation-top-dropdown-link" do %>
      <%= icon "cog-6" %> Settings
    <% end %>

    <%= link_to "#", class: "navigation-top-dropdown-link js-new-workspace-link" do %>
      <%= icon "plus" %> Create new workspace
    <% end %>

    <div class="navigation-top-dropdown-line"></div>

    <%= link_to destroy_user_session_path, method: :delete, class: "navigation-top-dropdown-link" do %>
      <%= icon "logout" %> Logout
    <% end %>
  </div>

  <div class="navigation-new-workspace-modal" data-open-on-load="<%= flash[:open_new_workspace_modal].present? ? '1' : '0' %>">
    <div class="navigation-new-workspace-modal-close"><%= icon "x-mark" %></div>
    <div class="navigation-new-workspace-modal-heading">Create new workspace</div>
    <div class="navigation-new-workspace-modal-line"></div>

    <%= form_with model: Workspace.new,
                  url: workspaces_path,
                  method: :post,
                  local: true,
                  html: { class: "navigation-new-workspace-form" } do |f| %>

      <div class="navigation-new-workspace-modal-label">Workspace name</div>
      <%= f.text_field :name,
            value: flash[:new_workspace_name],
            placeholder: "i.e. Acme Co.",
            class: "navigation-new-workspace-modal-field js-new-workspace-name",
            autocomplete: "off" %>

      <%= f.submit "Create workspace", class: "navigation-new-workspace-modal-button" %>
    <% end %>
  </div>

  <div class="backdrop" aria-hidden="true"></div>

  <script>
    $(function() {
      var $dropdown        = $('.navigation-top-dropdown');
      var $workspaceButton = $('.navigation-workspace-button');
      var $newWorkspace    = $('.js-new-workspace-link');
      var $modal           = $('.navigation-new-workspace-modal');
      var $backdrop        = $('.backdrop');
      var $modalClose      = $('.navigation-new-workspace-modal-close');

      var $form      = $('.navigation-new-workspace-form');
      var $nameInput = $('.js-new-workspace-name');

      function closeModalAndBackdrop() {
        $modal.hide();
        $dropdown.stop(true, true).slideUp(150);
        $workspaceButton.removeClass('is-open');
        $nameInput.removeClass('is-invalid');

        $backdrop
          .removeClass('backdrop--workspace-modal')
          .removeClass('backdrop--workspace-modal-visible');
      }

      function emitToastError(message) {
        if (window.showToast) return window.showToast(message, "error");
        if (window.toast)     return window.toast(message, "error");
        alert(message);
      }

      function markInvalid() { $nameInput.addClass('is-invalid'); }
      function clearInvalid() { $nameInput.removeClass('is-invalid'); }

      // Toggle dropdown on workspace button click
      $workspaceButton.on('click', function(e) {
        e.preventDefault();
        e.stopPropagation();

        $dropdown.stop(true, true).slideToggle(150);
        $workspaceButton.toggleClass('is-open');
      });

      // Open "new workspace" modal from dropdown
      $newWorkspace.on('click', function(e) {
        e.preventDefault();
        e.stopPropagation();

        $dropdown.stop(true, true).slideUp(150);
        $workspaceButton.removeClass('is-open');
        clearInvalid();

        $modal.show();

        $backdrop
          .addClass('backdrop--workspace-modal')
          .addClass('backdrop--workspace-modal-visible');

        setTimeout(function() { $nameInput.focus(); }, 0);
      });

      // Clicking backdrop closes modal/dropdown
      $backdrop.on('click', function() {
        closeModalAndBackdrop();
      });

      // Clicking X closes modal/dropdown
      $modalClose.on('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        closeModalAndBackdrop();
      });

      // Close dropdown when clicking outside (but don't close modal)
      $(document).on('click', function(e) {
        if (!$(e.target).closest('.navigation-top-dropdown, .navigation-workspace-button, .navigation-new-workspace-modal').length) {
          $dropdown.stop(true, true).slideUp(150);
          $workspaceButton.removeClass('is-open');
        }
      });

      $nameInput.on('input', function() {
        clearInvalid();
      });

      $form.on('submit', function(e) {
        var raw  = ($nameInput.val() || '');
        var name = raw.trim();

        if (!name.length) {
          e.preventDefault();
          markInvalid();
          emitToastError("Workspace name cannot be blank.");
          $nameInput.focus();
          return false;
        }

        $nameInput.val(name.replace(/\s+/g, ' '));
      });

      if (($modal.data('open-on-load') || '0').toString() === '1') {
        $modal.show();

        $backdrop
          .addClass('backdrop--workspace-modal')
          .addClass('backdrop--workspace-modal-visible');

        var currentVal = ($nameInput.val() || '').trim();
        if (!currentVal.length) markInvalid();

        setTimeout(function() { $nameInput.focus(); }, 0);
      }
    });
  </script>
<% end %>
