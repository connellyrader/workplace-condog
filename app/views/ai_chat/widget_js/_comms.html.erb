<script>
/* ============================== Chat Widget — Communication & Interactions (spinner until first token) ============================== */
(function (global){
  var W = global.AiChatWidget; if (!W) return;
  function csrf(){ var m=document.querySelector('meta[name="csrf-token"]'); return m && m.content; }

  /* ---- open + socket ---- */
  W.prototype.openConversation = async function(id){
    if (this.subscription && this.subscription.unsubscribe) this.subscription.unsubscribe();
    this.currentConversationId = id;
    this.renderConversationList();

    var res = await fetch(this.showUrl.replace(":id", id), { headers: { "Accept":"application/json" } });
    if(!res.ok) throw new Error("Failed to open conversation");
    var data = await res.json();

    if (this.updateConversationTitle) this.updateConversationTitle(data.title);

    if (this.threadEl) {
      this.threadEl.innerHTML = "";
      var self = this;
      var msgs = data.messages || [];
      var ds = this.root && this.root.dataset || {};

      // In home layout, if the conversation starts with a user message,
      // prepend the intro greeting (it's not persisted server-side)
      if (ds.aiChatWidgetLayoutValue === "home" && msgs.length && msgs[0].role === "user") {
        self.appendMessageBubble("assistant", "Hey! I\u2019m your Workplace assistant. What would you like to call me?");
      }

      msgs.forEach(function(m){
        var bubble = self.appendMessageBubble(m.role, m.content);
        self.processInlineMarkers && self.processInlineMarkers(bubble);

        if (Array.isArray(m.inline_blocks) && m.inline_blocks.length) {
          for (var i = 0; i < m.inline_blocks.length; i++) {
            var b = m.inline_blocks[i];
            if (b && b.anchor) self.insertInlineBlock && self.insertInlineBlock(b.anchor, b);
          }
        }
      });

      // Track conversations that have had dummy messages
      self._dummyConvos = self._dummyConvos || {};
      if (!msgs.length && !self._dummyConvos[id]) {
        this.renderEmptyIntro && this.renderEmptyIntro();
      } else {
        this.clearEmptyIntro && this.clearEmptyIntro();
        // Restore dummy messages if they exist
        if (!msgs.length && self._dummyConvos[id]) {
          self._dummyConvos[id].forEach(function(m){
            var bubble = self.appendMessageBubble(m.role, "");
            var msgEl = bubble && bubble.querySelector(".ai-msg");
            if (msgEl) {
              var html = ""; try { html = global.__renderMarkdown ? global.__renderMarkdown(m.content) : ""; } catch(_){}
              if (html && html.trim()) msgEl.innerHTML = html; else msgEl.textContent = m.content;
            }
          });
        }
      }
    }

    this._streamingActive = false;
    this._scroll && this._scroll();
    this.showScrollToBottom && this.showScrollToBottom(false);

    var self = this;
    this.subscription = this.consumer.subscriptions.create(
      { channel: "AiChat::ChatChannel", conversation_id: id },
      {
        received: function(payload){
          var root = self.root || document;
          self.threadEl = self.threadEl || root.querySelector(".ai-chat__thread");
          if (!self.threadEl) return;

          if (payload.type === "stream_start") {
            self._currentStreamId = payload.stream_id || null;
            self._currentStreamSeq = 0;
            self._streamingActive = true;
            self._updateStickyState && self._updateStickyState();
            var bStart = self.ensureAssistantBubble && self.ensureAssistantBubble();
            if (self.resetStreamBubble) self.resetStreamBubble(bStart, { keepSpinner: true });
            return;
          }

          if (payload.type === "token") {
            if (payload.stream_id && self._currentStreamId && payload.stream_id !== self._currentStreamId) return;
            if (payload.stream_id && !self._currentStreamId) self._currentStreamId = payload.stream_id;
            if (typeof payload.seq === "number") {
              self._currentStreamSeq = self._currentStreamSeq || 0;
              if (payload.seq <= self._currentStreamSeq) return;
              self._currentStreamSeq = payload.seq;
            }
            self.handleToken(payload.token, payload.output_index);     // hides spinner on first token
            return;
          }

          if (payload.type === "status") {
            self.updateStatus && self.updateStatus(payload);
            return;
          }


          if (payload.type === "embed" && payload.kind === "sparkline" && payload.url) {
            var last = self.ensureAssistantBubble(); if (!last) return;
            self.removeSpinner(last);            // just in case
            var blocksEl = self.ensureBlocksContainer(last);
            var fig = document.createElement("figure"); fig.className = "ai-chart ai-widget";
            var img = document.createElement("img");
            img.src = payload.url; img.alt = (payload.label || "Chart"); img.className = "ai-chat__sparkline"; img.loading = "lazy";
            fig.appendChild(img);
            if (payload.label) {
              var cap = document.createElement("figcaption"); cap.className = "ai-chart__caption"; cap.textContent = payload.label;
              fig.appendChild(cap);
            }
            blocksEl.appendChild(fig);
            return;
          }


          if (payload.type === "rename" && payload.conversation) {
            var c = payload.conversation || {};
            var id = c.id, title = c.title || ("Conversation #" + id);
            // update local cache
            if (Array.isArray(self.conversations)) {
              for (var i=0; i<self.conversations.length; i++) {
                if (self.conversations[i].id === id) {
                  self.conversations[i].title = title;
                  break;
                }
              }
            }
            // re-render list highlighting the current row
            self.renderConversationList();
            if (self.currentConversationId === id && self.updateConversationTitle) {
              self.updateConversationTitle(title);
            }
            return;
          }

          if (payload.type === "error") {
            var bErr = self.ensureAssistantBubble();
            self.removeSpinner(bErr);
            self.appendSystem("[Error] " + (payload.message || "Unknown error"));
            if (self.setComposerEnabled) self.setComposerEnabled(true);
            return;
          }

          if (payload.type === "done") {
            var bDone = self.findLastAssistantBubble() || self.ensureAssistantBubble();
            self.removeSpinner(bDone);
            self.clearStatusWidget && self.clearStatusWidget(bDone);

            if (payload.inline_blocks && payload.inline_blocks.length) {
              self._pendingInlineBlocks = self._pendingInlineBlocks || {};
              (payload.inline_blocks || []).forEach(function(b){
                if (b && b.anchor) self._pendingInlineBlocks[b.anchor] = b;
              });
            }

            if (payload.content) {
              var msg = self.ensureMsgContainer(bDone);
              if (msg) {
                msg.__raw = String(payload.content);
                msg.__node = null;
              }
            }

            if (bDone) {
              // 1) Convert accumulated markdown to HTML
              self.flushMarkdown(bDone);
              // 2) Replace {{block:ID}} with slots and insert queued inline widgets
              self.processInlineMarkers && self.processInlineMarkers(bDone);
              // 3) Staggered blur-in reveal
              self._revealMsg && self._revealMsg(bDone);
            }

            if (self.setComposerEnabled) self.setComposerEnabled(true);
            self._streamingActive = false;
            self._scroll();
            self.showScrollToBottom && self.showScrollToBottom(false);
            return;
          }
        }
      }
    );
  };

  /* ---- sending ---- */
  W.prototype.send = async function(e){
    if (e && e.preventDefault) e.preventDefault();
    if (!this.inputEl) return;

    // If we're already waiting on a reply, ignore further sends
    if (this.sendBtnEl && this.sendBtnEl.disabled) return;

    var content = this.inputEl.value.trim();
    if (!content) return;

    // Lazily create the conversation on first send (user clicked "New Conversation"
    // which shows the landing but doesn't create anything until they actually send)
    if (!this.currentConversationId && this.createConversation) {
      try { await this.createConversation(); } catch (_) { return; }
    }

    // Hide intro / landing once user starts a real thread
    this.clearEmptyIntro && this.clearEmptyIntro();

    // 🔹 Disable composer + add loading state
    if (this.setComposerEnabled) {
      this.setComposerEnabled(false);
    } else if (this.sendBtnEl) {
      this.sendBtnEl.disabled = true;
    }

    this.inputEl.value = "";
    this._resizeInput && this._resizeInput();
    this._updateSendReady && this._updateSendReady();
    this.appendMessageBubble("user", content);

    // create placeholder assistant bubble + spinner while waiting for first token
    var pending = this.appendMessageBubble("assistant", "");
    this.showSpinner && this.showSpinner(pending, "Thinking…");

    // ── Dummy response mode (no LLM needed) ──
    var dummyMode = true;
    if (dummyMode) {
      var self = this;

      // Detect the scripted onboarding conversation by its title.
      // When active, user messages walk through AiChatWidget._onboardingScript
      // instead of getting random dummy responses.
      var currentConv = null;
      if (self.conversations && self.currentConversationId) {
        for (var _ci = 0; _ci < self.conversations.length; _ci++) {
          if (self.conversations[_ci].id === self.currentConversationId) {
            currentConv = self.conversations[_ci];
            break;
          }
        }
      }
      var isScripted = !!(currentConv && AiChatWidget.ONBOARDING_TITLE &&
                          currentConv.title === AiChatWidget.ONBOARDING_TITLE);

      // Only set the title on the very first message in this conversation
      // (but never rename the scripted onboarding conversation).
      var isFirstMessage = !(self._dummyConvos && self._dummyConvos[self.currentConversationId] && self._dummyConvos[self.currentConversationId].length);
      if (isFirstMessage && !isScripted) {
        var dummyTitle = content.length > 40 ? content.substring(0, 40) + "…" : content;
        if (self.updateConversationTitle) self.updateConversationTitle(dummyTitle);
        if (self.currentConversationId && Array.isArray(self.conversations)) {
          for (var ci = 0; ci < self.conversations.length; ci++) {
            if (self.conversations[ci].id === self.currentConversationId) {
              self.conversations[ci].title = dummyTitle;
              break;
            }
          }
          self.renderConversationList && self.renderConversationList();
        }
      }

      /* Show analyzing bar on first follow-up message (but not in scripted mode) */
      if (!isFirstMessage && !isScripted && !self._analyzingBar) {
        self.showAnalyzingBar && self.showAnalyzingBar();
      }

      var dummyResponses = [
        {
          text: "Great question! Based on the team's recent activity, engagement has been trending upward over the past two weeks. The biggest contributors have been the **weekly standups** and the new **async check-in** process that was introduced last month.\n\nHere are a few highlights:\n\n- **Participation rate** is up 12% compared to last period\n- **Response time** on team threads has improved by 18%\n- **Sentiment scores** remain steady at 7.8/10\n\nWould you like me to dig deeper into any of these areas?"
        },
        {
          text: "Here's a breakdown of team engagement across the workspace this period:",
          blocks: [
            {
              type: "kpis",
              title: "Key Metrics — Last 14 Days",
              items: [
                { label: "Engagement Score", value: "82%", pos_rate: 0.06 },
                { label: "Active Contributors", value: "24", pos_rate: 0.26 },
                { label: "Avg Response Time", value: "2.4h", pos_rate: -0.23 },
                { label: "Sentiment", value: "7.8", pos_rate: 0.04 }
              ]
            },
            {
              type: "table",
              title: "Top Contributors",
              columns: ["Name", "Messages", "Reactions Given", "Threads Started"],
              rows: [
                ["Sarah Chen", "142", "89", "12"],
                ["Marcus Johnson", "118", "74", "9"],
                ["Priya Patel", "96", "112", "15"],
                ["Alex Kim", "87", "65", "7"],
                ["Jordan Rivera", "73", "58", "11"]
              ]
            }
          ]
        },
        {
          text: "Sure thing! Here's a quick summary of the key metrics:\n\n| Metric | This Period | Last Period | Change |\n|--------|-----------|------------|--------|\n| Engagement Score | 82% | 76% | +6% |\n| Active Contributors | 24 | 19 | +5 |\n| Avg Response Time | 2.4h | 3.1h | -0.7h |\n| Sentiment | 7.8 | 7.5 | +0.3 |\n\nLet me know if you'd like to explore any of these in more detail."
        },
        {
          text: "I've analyzed the Slack activity across **#engineering**, **#design**, and **#product**. Here's what I found:",
          blocks: [
            {
              type: "kpis",
              items: [
                { label: "Total Messages", value: "1,247" },
                { label: "Active Channels", value: "18" },
                { label: "Avg Daily Active", value: "34" },
                { label: "Peak Hour", value: "10am" }
              ]
            },
            {
              type: "callout",
              text: "**Heads up:** The **#engineering** channel saw a 40% spike in messages last Thursday — likely related to the incident response. Sentiment dipped to 6.2 during that window but has since recovered to 7.9."
            }
          ]
        },
        {
          text: "Looking at the data, here's what stands out:\n\n1. **Monday mornings** tend to have the highest collaboration activity\n2. **Cross-team interactions** have increased by 23% since the reorg\n3. There's a noticeable dip in engagement on Fridays after 2pm\n\nThe overall trend is positive. Your team seems to be finding a good rhythm with the new workflow."
        },
        {
          text: "That's a really interesting observation. From what I can see, the team dynamic shifted notably after the **Q3 planning session**. A few things that might explain it:\n\n- New team members have been actively participating in discussions\n- The introduction of **themed meeting days** reduced context-switching\n- Management has been more visible in channels, which tends to boost engagement\n\nI'd recommend keeping an eye on the burnout indicators though — high engagement is great, but sustained intensity can sometimes lead to fatigue."
        }
      ];
      // Store dummy messages for this conversation so they persist on nav.
      // We push BEFORE picking the response so script indexing is correct
      // (the Nth user message maps to script step N-1).
      self._dummyConvos = self._dummyConvos || {};
      if (!self._dummyConvos[self.currentConversationId]) {
        self._dummyConvos[self.currentConversationId] = [];
      }
      self._dummyConvos[self.currentConversationId].push({ role: "user", content: content });

      var pick;
      var scriptedThoughtSeq = null;

      if (isScripted) {
        // Count user messages so far (this one included) to determine script state
        var userMsgCount = 0;
        var convStore = self._dummyConvos[self.currentConversationId] || [];
        for (var um = 0; um < convStore.length; um++) {
          if (convStore[um].role === "user") userMsgCount++;
        }

        var scriptStep = AiChatWidget._onboardingScript[userMsgCount - 1];
        if (scriptStep) {
          pick = { text: scriptStep.text, blocks: scriptStep.blocks || null };
          scriptedThoughtSeq = scriptStep.thoughtSeq || null;
          // stash side-effect flags for the post-render step
          var _scriptStartAnalyzing = !!scriptStep.startAnalyzingBar;
          var _scriptFollowUp       = scriptStep.followUp || null;
        } else {
          // Script exhausted — graceful fallback so the chat keeps working.
          pick = {
            text: "We're all set. You can ask me about anything from here — try something like \"how is engagement looking across the team this week?\""
          };
        }
      } else {
        // Random pick from the regular dummy pool, never repeating the last one
        if (typeof self._lastDummyIdx !== "number") self._lastDummyIdx = -1;
        var idx;
        do { idx = Math.floor(Math.random() * dummyResponses.length); } while (idx === self._lastDummyIdx && dummyResponses.length > 1);
        self._lastDummyIdx = idx;
        pick = dummyResponses[idx];
      }

      var reply = pick.text;
      var replyBlocks = pick.blocks || null;

      // Thinking time:
      //   Scripted onboarding chat: short 2–4s with a plain "Thinking…" (no
      //     reasoning drawer or phrase cycling — feels more like a chat).
      //   Everything else: the usual 6–12s with reasoning progression.
      var thinkSeconds, thinkMs;
      if (isScripted) {
        thinkSeconds = Math.floor(Math.random() * 3) + 2; // 2..4
        thinkMs = thinkSeconds * 1000;
      } else {
        thinkSeconds = Math.floor(Math.random() * 7) + 6; // 6..12
        thinkMs = thinkSeconds * 1000;
      }

      // Only schedule the reasoning phrase cycling in non-scripted mode.
      // Scripted onboarding keeps the shimmering "Thinking…" the whole time.
      var thoughtSeq = null;
      if (!isScripted) {
        thoughtSeq = scriptedThoughtSeq ||
                     (self._pickThoughtSequence ? self._pickThoughtSequence() : null);
        if (thoughtSeq && self._scheduleThoughtProgress) {
          self._scheduleThoughtProgress(pending, thoughtSeq, thinkMs);
        }
      }

      setTimeout(function(){
        self.removeSpinner && self.removeSpinner(pending);
        var msg = pending && pending.querySelector(".ai-msg");

        // Insert "Thought for X seconds" summary + reasoning drawer above content.
        // Skipped in the scripted onboarding chat — that chat feels more like a
        // conversation, so we don't dress it up with reasoning UI.
        if (msg) {
          if (!isScripted && self._buildThoughtBlock) {
            msg.appendChild(self._buildThoughtBlock(thinkSeconds, content, thoughtSeq));
          }

          var html = ""; try { html = global.__renderMarkdown ? global.__renderMarkdown(reply) : ""; } catch(_){}
          var body = document.createElement("div");
          body.className = "ai-msg__body";
          if (html && html.trim()) body.innerHTML = html; else body.textContent = reply;
          msg.appendChild(body);
        }

        // Render rich blocks (KPI cards, tables, callouts) after text
        if (replyBlocks && replyBlocks.length && msg) {
          try {
            var blocksWrap = document.createElement("div");
            blocksWrap.className = "ai-blocks";
            msg.appendChild(blocksWrap);
            if (self.renderBlocksInto) self.renderBlocksInto(blocksWrap, replyBlocks);
          } catch (blockErr) {
            console.warn("[Clara] Block rendering error:", blockErr);
          }
        }

        // Staggered blur-in reveal
        self._revealMsg && self._revealMsg(pending);
        // Store the assistant reply too
        self._dummyConvos[self.currentConversationId].push({ role: "assistant", content: reply });

        if (self.setComposerEnabled) self.setComposerEnabled(true);
        else if (self.sendBtnEl) self.sendBtnEl.disabled = false;
        self._scroll && self._scroll();

        // Re-focus the input so the user can keep typing without clicking back.
        if (self.inputEl && typeof self.inputEl.focus === "function") {
          self.inputEl.focus({ preventScroll: true });
        }

        // Scripted side-effects: kick off the analyzing bar and/or queue an
        // automatic follow-up assistant message.
        if (isScripted) {
          if (_scriptStartAnalyzing && self.showAnalyzingBar) {
            self.showAnalyzingBar();
          }

          if (_scriptFollowUp) {
            setTimeout(function(){
              if (!self.appendMessageBubble) return;
              var fu = self.appendMessageBubble("assistant", "");
              self.showSpinner && self.showSpinner(fu, "Thinking…");
              // Make sure the new thinking bubble is visible above the
              // analyzing bar + gradient at the bottom of the composer.
              self.scrollToBottom && self.scrollToBottom();
              self._scroll && self._scroll();

              var fuThinkMs = 1600; // short beat before the follow-up arrives

              setTimeout(function(){
                self.removeSpinner && self.removeSpinner(fu);
                var fuMsg = fu && fu.querySelector(".ai-msg");
                if (fuMsg) {
                  var fuHtml = "";
                  try { fuHtml = global.__renderMarkdown ? global.__renderMarkdown(_scriptFollowUp.text) : ""; } catch(_){}
                  var fuBody = document.createElement("div");
                  fuBody.className = "ai-msg__body";
                  if (fuHtml && fuHtml.trim()) fuBody.innerHTML = fuHtml; else fuBody.textContent = _scriptFollowUp.text;
                  fuMsg.appendChild(fuBody);
                }
                self._revealMsg && self._revealMsg(fu);
                self._dummyConvos[self.currentConversationId].push({ role: "assistant", content: _scriptFollowUp.text });
                self._scroll && self._scroll();
                if (self.inputEl && typeof self.inputEl.focus === "function") {
                  self.inputEl.focus({ preventScroll: true });
                }
              }, fuThinkMs);
            }, _scriptFollowUp.delayMs || 2500);
          }
        }
      }, thinkMs);
      this.scrollToBottom && this.scrollToBottom();
      return;
    }
    // ── End dummy response mode ──

    // Live mode requires a live subscription
    if (!this.subscription || !this.subscription.perform) return;

    var payload = {
      content: content,
      options: { timeframe: "last_14_days" }
    };

    this.subscription.perform("send_message", payload);
    this.scrollToBottom && this.scrollToBottom();
  };

  /* ---- async delete conversation ---- */
  W.prototype.deleteConversation = async function(id){
    try{
      var url = this.showUrl.replace(":id", id);
      var res = await fetch(url, {
        method: "DELETE",
        headers: { "X-CSRF-Token": csrf(), "Accept":"application/json" }
      });
      if (!res.ok && res.status !== 204) throw new Error("Delete failed");

      this.conversations = (this.conversations || []).filter(function(c){ return c.id !== id; });
      this.removeConversationFromUI(id);

      if (this.currentConversationId === id) {
        if (this.conversations.length) {
          this.openConversation(this.conversations[0].id);
        } else {
          await this.createConversation();
        }
      }
    } catch(e){
      console.error("deleteConversation", e);
      if (global.AiConfirm && typeof global.AiConfirm.toast === "function") {
        global.AiConfirm.toast("Failed to delete conversation.");
      }
    }
  };

  W.prototype.removeConversationFromUI = function(id){
    if (this.conversationListEl) {
      var row = this.conversationListEl.querySelector('.ai-chat__list-item[data-id="'+id+'"]');
      if (row && row.parentNode) row.parentNode.removeChild(row);
    }
    this.renderConversationList();
  };

    // Update spinner label + optional "thinking widget" inside the assistant bubble
  W.prototype.updateStatus = function(status){
    var bubble = this.ensureAssistantBubble && this.ensureAssistantBubble();
    if (!bubble) return;

    var msg = status.message || (status.tool && status.tool.label ? ("Thinking — " + status.tool.label) : "Thinking…");
    this.showSpinner && this.showSpinner(bubble, msg);

    // no auto-scroll on status updates
  };

  // Render a small card that shows what tool is running + facets/date window/etc.
  W.prototype.renderStatusWidget = function(bubble, status){
    var tool   = status.tool   || {};
    var ctx    = status.context || {};
    var kind   = tool.kind || "other";
    var phase  = status.phase || "tool_call";

    // Create or reuse a container inside the assistant bubble
    var container = bubble.querySelector(".ai-chat__status");
    if (!container) {
      container = document.createElement("div");
      container.className = "ai-chat__status";
      bubble.appendChild(container);
    }
    container.innerHTML = "";

    var card = document.createElement("div");
    card.className = "ai-chat__status-card ai-chat__status-card--" + kind;

    var title = document.createElement("div");
    title.className = "ai-chat__status-title";
    title.textContent = tool.label || "Working…";
    card.appendChild(title);

    var meta = document.createElement("div");
    meta.className = "ai-chat__status-meta";

    var pieces = [];

    // Facet(s)
    var facet = ctx.facet || (Array.isArray(ctx.facets) && ctx.facets[0]);
    if (facet) pieces.push(facet);

    // Range (single)
    if (ctx.range && (ctx.range.from || ctx.range.to)) {
      var rf = ctx.range.from || "…";
      var rt = ctx.range.to   || "…";
      pieces.push(rf + " → " + rt);
    }

    // Metric
    if (ctx.metric) {
      pieces.push(ctx.metric);
    }

    // Batch count
    if (typeof ctx.operations_count === "number") {
      pieces.push(ctx.operations_count + " op" + (ctx.operations_count === 1 ? "" : "s"));
    }

    // Guidance query
    if (ctx.query && tool.kind === "guidance") {
      pieces.push("“" + ctx.query + "”");
    }

    meta.textContent = pieces.join(" · ");
    card.appendChild(meta);

    // Placeholder visual – looks like a little loading chart/cards area
    // var placeholder = document.createElement("div");
    // placeholder.className = "ai-chat__status-placeholder";
    // card.appendChild(placeholder);

    // container.appendChild(card);
  };


  W.prototype.clearStatusWidget = function(bubble){
    bubble = bubble || (this.ensureAssistantBubble && this.ensureAssistantBubble());
    if (!bubble) return;
    var container = bubble.querySelector(".ai-chat__status");
    if (container && container.parentNode) {
      container.parentNode.removeChild(container);
    }
  };


  // ---- empty thread intro helpers ----
  W.prototype.clearEmptyIntro = function(){
    if (!this.threadEl) return;
    var el = this.threadEl.querySelector(".ai-chat__intro");
    if (el && el.parentNode) el.parentNode.removeChild(el);
    var empties = this.threadEl.querySelectorAll("[data-intro-empty='1']");
    Array.prototype.forEach.call(empties, function(b){
      if (b && b.parentNode) b.parentNode.removeChild(b);
    });
    // Also clean up the landing page
    var mainEl = this.root && this.root.querySelector(".ai-chat__main");
    if (mainEl && mainEl.classList.contains("ai-chat__main--landing")) {
      var composer = mainEl.querySelector(".ai-chat__composer");

      // FLIP animation: capture composer's current position before DOM change
      var firstRect = composer ? composer.getBoundingClientRect() : null;

      // Move composer back to its original position (end of main)
      if (composer && composer.parentNode !== mainEl) {
        mainEl.appendChild(composer);
      }
      // Restore placeholder
      if (this.inputEl && this._origPlaceholder != null) {
        this.inputEl.placeholder = this._origPlaceholder;
      }
      // Remove landing elements
      var landing = mainEl.querySelector(".ai-chat__landing");
      if (landing && landing.parentNode) landing.parentNode.removeChild(landing);

      // Remove landing state so layout resolves to final position
      mainEl.classList.remove("ai-chat__main--landing");

      // FLIP: calculate delta and animate composer from old pos to new
      if (composer && firstRect) {
        var lastRect = composer.getBoundingClientRect();
        var dy = firstRect.top - lastRect.top;
        var dx = firstRect.left - lastRect.left;

        if (Math.abs(dy) > 5 || Math.abs(dx) > 5) {
          composer.style.transform = "translate(" + dx + "px, " + dy + "px)";
          composer.style.transition = "none";
          // Force reflow so the transform is applied before we animate
          composer.offsetHeight;
          composer.style.transition = "transform 0.45s cubic-bezier(0.16, 1, 0.3, 1)";
          composer.style.transform = "translate(0, 0)";

          composer.addEventListener("transitionend", function cleanup(e){
            if (e.propertyName === "transform") {
              composer.style.transform = "";
              composer.style.transition = "";
              composer.removeEventListener("transitionend", cleanup);
            }
          });
        }
      }

      // Fade in the thread area
      mainEl.classList.add("ai-chat__main--landing-exit");
      setTimeout(function(){
        mainEl.classList.remove("ai-chat__main--landing-exit");
      }, 500);
    }
  };

  W.prototype.renderEmptyIntro = function(){
    if (!this.threadEl) return;

    this.clearEmptyIntro();

    var ds = this.root.dataset || {};
    if (ds.aiChatWidgetLayoutValue === "home") {
      var self = this;
      var mainEl = this.root.querySelector(".ai-chat__main");
      if (!mainEl) return;

      // Show landing state
      mainEl.classList.add("ai-chat__main--landing");

      // Set topbar title to model name on landing
      if (self.titleEl) self.titleEl.textContent = "CLARA v26.040";

      // Build landing container with heading
      var landing = document.createElement("div");
      landing.className = "ai-chat__landing";

      var heading = document.createElement("h1");
      heading.className = "ai-chat__landing-heading";
      heading.textContent = "What can I do for you?";
      landing.appendChild(heading);

      // Move the real composer into the landing div
      var composer = mainEl.querySelector(".ai-chat__composer");
      if (composer) {
        landing.appendChild(composer);
      }

      // Swap placeholder text
      if (self.inputEl) {
        self._origPlaceholder = self.inputEl.placeholder;
        self.inputEl.placeholder = "Assign a task or ask anything...";
      }

      // Examples section
      var examples = [
        { title: "Analyze engagement", desc: "Review engagement trends across your teams and identify the areas that need the most attention" },
        { title: "Research a topic", desc: "Explore topics like psychological safety, burnout, or alignment across your organization" },
        { title: "Draft a team update", desc: "Turn culture signals and recent data into a clear, concise update for leadership" }
      ];

      var exWrap = document.createElement("div");
      exWrap.className = "ai-chat__landing-examples";

      var exHeading = document.createElement("div");
      exHeading.className = "ai-chat__landing-examples-heading";
      exHeading.textContent = "Get started with some examples";
      exWrap.appendChild(exHeading);

      var exGrid = document.createElement("div");
      exGrid.className = "ai-chat__landing-examples-grid";

      examples.forEach(function(ex){
        var card = document.createElement("button");
        card.type = "button";
        card.className = "ai-chat__landing-example-card";
        var t = document.createElement("div");
        t.className = "ai-chat__landing-example-title";
        t.textContent = ex.title;
        var d = document.createElement("div");
        d.className = "ai-chat__landing-example-desc";
        d.textContent = ex.desc;
        card.appendChild(t);
        card.appendChild(d);

        card.addEventListener("click", function(){
          if (self.inputEl) {
            self.inputEl.value = ex.title + ". " + ex.desc;
            self.inputEl.dispatchEvent(new Event("input", { bubbles: true }));
            self.inputEl.focus();
          }
        });

        exGrid.appendChild(card);
      });

      exWrap.appendChild(exGrid);
      landing.appendChild(exWrap);

      // Insert landing before thread-wrap
      var threadWrap = mainEl.querySelector(".ai-chat__thread-wrap");
      mainEl.insertBefore(landing, threadWrap);

      return;
    }

    function pickRandom(arr, n){
      // Fisher–Yates shuffle copy, then take n
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
      }
      return a.slice(0, n);
    }

    var allPrompts = [
      "Summarize the biggest risks in the last 14 days.",
      "What are the top negative signals and where are they coming from?",
      "Compare this week vs last week for burnout and engagement.",
      "Explain Psychological Safety and how to improve it.",
      "What’s driving execution risk right now?",
      "Show me the biggest week-over-week changes by submetric.",
      "Which channels have the highest conflict signals?",
      "What are the top positive signals we should reinforce?",
      "Give me 3 concrete actions to reduce burnout this month.",
      "Where are we seeing misalignment and why?",
      "Which teams are trending worse over the last 30 days?",
      "Summarize the key themes for leadership in plain English.",
      "What’s the healthiest area of the culture right now?",
      "What’s the riskiest area of the culture right now?",
      "Break down engagement signals by subcategory.",
      "Compare the last 30 days to the prior 30 days.",
      "What do the signals suggest about communication quality?",
      "Highlight any early warning signs we should watch.",
      "What’s the most common source of negative sentiment?",
      "Which metric improved most over the last two weeks?",
      "What’s the best next step for managers this week?",
      "Draft a short message leaders can send to address the top issue.",
      "What questions should I ask in 1:1s based on these signals?",
      "Identify the top 3 drivers of conflict and how to mitigate them.",
      "Are we seeing signs of overload or unsustainable pace?",
      "Which areas show signs of low trust or fear of speaking up?",
      "What’s the likely root cause of execution risk signals?",
      "Give me a simple action plan for the next 7 days.",
      "Summarize signals by channel and flag outliers.",
      "Explain what “Alignment” means in this context with examples."
    ];

    var prompts = pickRandom(allPrompts, 3);

    var wrap = document.createElement("div");
    wrap.className = "ai-chat__intro";

    var title = document.createElement("div");
    title.className = "ai-chat__intro-title";
    title.textContent = "Get started with CLARA";
    wrap.appendChild(title);

    var desc = document.createElement("div");
    desc.className = "ai-chat__intro-desc";
    desc.textContent = "Try one of these prompts, or ask a question about your culture signals:";
    wrap.appendChild(desc);

    var list = document.createElement("div");
    list.className = "ai-chat__intro-prompts";

    var self = this;
    prompts.forEach(function(p){
      var btn = document.createElement("button");
      btn.type = "button";
      btn.className = "ai-chat__intro-prompt";
      btn.textContent = p;

      btn.addEventListener("click", function(){
        if (!self.inputEl) return;
        self.inputEl.value = p;

        // Hide intro immediately and submit
        self.clearEmptyIntro && self.clearEmptyIntro();
        self.send && self.send(); // send() now tolerates no event
      });

      list.appendChild(btn);
    });

    wrap.appendChild(list);

    var links = document.createElement("div");
    links.className = "ai-chat__intro-links";
    links.innerHTML =
      'Ready to learn more? Read our ' +
      '<a href="<%= j clara_docs_path %>">CLARA Docs</a>';
    wrap.appendChild(links);

    this.threadEl.appendChild(wrap);
    this._scroll && this._scroll();
    this.showScrollToBottom && this.showScrollToBottom(false);
  };



})(window);
</script>
