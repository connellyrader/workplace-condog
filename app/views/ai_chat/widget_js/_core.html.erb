  /* Pick a random thought sequence for this turn. Exposed so the same sequence
     can be used both for the live label cycling AND the final drawer. */
  AiChatWidget.prototype._pickThoughtSequence = function(){
    var sequences = AiChatWidget._thoughtSequences;
    return sequences[Math.floor(Math.random() * sequences.length)];
  };

  /* While the spinner is active, cycle the "Thinking…" label through the
     sequence of reasoning / tool lines with a subtle blur-fade between each. */
  AiChatWidget.prototype._scheduleThoughtProgress = function(pending, sequence, thinkMs){
    if (!pending || !sequence || !sequence.length) return [];
    var labelEl = pending.querySelector(".ai-typing__label");
    if (!labelEl) return [];

    var phrases = sequence.map(function(s){
      return s.type === "tool" ? s.label : s.text;
    });

    // Leave a small tail so the spinner isn't removed mid-fade
    var cycleMs = Math.max(800, thinkMs - 300);
    var perPhrase = cycleMs / (phrases.length + 1); // phase 0 = "Thinking…"

    // If each phase would be too short (below the fade time), truncate phrases
    var MIN_PER_PHASE = 450;
    if (perPhrase < MIN_PER_PHASE) {
      var maxPhases = Math.max(0, Math.floor(cycleMs / MIN_PER_PHASE) - 1);
      phrases = phrases.slice(0, maxPhases);
      perPhrase = phrases.length ? cycleMs / (phrases.length + 1) : cycleMs;
    }

    var FADE_MS = 180;
    var timers = [];

    phrases.forEach(function(text, idx){
      var at = perPhrase * (idx + 1); // skip phase 0
      timers.push(setTimeout(function(){
        if (!labelEl.isConnected) return;
        labelEl.classList.add("ai-typing__label--fading");
        setTimeout(function(){
          if (!labelEl.isConnected) return;
          labelEl.textContent = text;
          // Drop the shimmer once we've moved past "Thinking…"
          labelEl.classList.remove("ai-typing__label--shimmer");
          labelEl.classList.remove("ai-typing__label--fading");
        }, FADE_MS);
      }, at));
    });

    return timers;
  };

  /* Build the "Thought for X seconds" block with an expandable drawer
     showing the reasoning steps the agent went through.
     If `seq` is provided, it will be used instead of picking a new random one. */
  AiChatWidget.prototype._buildThoughtBlock = function(seconds, promptText, seq){
    var wrap = document.createElement("div");
    wrap.className = "ai-thought";

    var summary = document.createElement("button");
    summary.type = "button";
    summary.className = "ai-thought-summary";
    summary.setAttribute("aria-expanded", "false");

    var label = document.createElement("span");
    label.className = "ai-thought-summary__text";
    label.textContent = "Thought for " + seconds + " second" + (seconds === 1 ? "" : "s");

    summary.appendChild(label);
    summary.insertAdjacentHTML("beforeend", AiChatWidget._thoughtIcons.chevronRight);

    // Use the sequence that was already cycled through the spinner label
    // (passed in), or fall back to a fresh random pick.
    if (!seq) seq = this._pickThoughtSequence();

    var drawer = document.createElement("div");
    drawer.className = "ai-thought-drawer";

    seq.forEach(function(s){
      var row = document.createElement("div");
      row.className = "ai-thought-step ai-thought-step--" + s.type;

      if (s.type === "tool") {
        row.insertAdjacentHTML("beforeend", AiChatWidget._thoughtIcons[s.icon] || "");
        var toolTxt = document.createElement("span");
        toolTxt.className = "ai-thought-step__label";
        toolTxt.textContent = s.label;
        row.appendChild(toolTxt);
      } else {
        // reasoning: bullet dot + narrative text
        var dot = document.createElement("span");
        dot.className = "ai-thought-step__dot";
        row.appendChild(dot);
        var txt = document.createElement("span");
        txt.className = "ai-thought-step__text";
        txt.textContent = s.text;
        row.appendChild(txt);
      }
      drawer.appendChild(row);
    });

    summary.addEventListener("click", function(){
      var open = wrap.classList.toggle("is-open");
      summary.setAttribute("aria-expanded", open ? "true" : "false");
    });

    wrap.appendChild(summary);
    wrap.appendChild(drawer);
    return wrap;
  };

  AiChatWidget.prototype._buildMsgActions = function(){
    var actions = [
      { key: "share",     label: "Share",         icon: AiChatWidget._actionIcons.share },
      { key: "copy",      label: "Copy",          icon: AiChatWidget._actionIcons.copy },
      { key: "thumbUp",   label: "Good response", icon: AiChatWidget._actionIcons.thumbUp },
      { key: "thumbDown", label: "Bad response",  icon: AiChatWidget._actionIcons.thumbDown }
    ];
    var wrap = document.createElement("div");
    wrap.className = "ai-msg-actions";
    for (var i = 0; i < actions.length; i++) {
      var a = actions[i];
      var btn = document.createElement("button");
      btn.type = "button";
      btn.className = "ai-msg-action";
      btn.dataset.action = a.key;
      btn.setAttribute("aria-label", a.label);
      btn.innerHTML = a.icon + '<span class="ai-msg-action__tooltip">' + a.label + '</span>';
      wrap.appendChild(btn);
    }
    return wrap;
  };

  AiChatWidget.prototype.appendMessageBubble = function(role, text){
    if (!this.threadEl) return null;
    var bubble = document.createElement("div");
    bubble.className = (role === "user") ? "ai-chat__bubble ai-chat__bubble--user" : "ai-chat__bubble ai-chat__bubble--assistant";
    bubble.dataset.role = role;
    var msg = document.createElement("div"); msg.className = "ai-msg"; msg.__mdBuf = null;
    if (text) {
      var html = ""; try { html = global.__renderMarkdown ? global.__renderMarkdown(text) : ""; } catch(_){}
      if (html && html.trim()) msg.innerHTML = html; else msg.textContent = text;
    }
    var blocks = document.createElement("div"); blocks.className = "ai-blocks";
    bubble.appendChild(msg); bubble.appendChild(blocks);
    /* Action bar (hover-reveal) for assistant messages only */
    if (role === "assistant") {
      bubble.appendChild(this._buildMsgActions());
    }
    this.threadEl.appendChild(bubble);
    // no auto-scroll on append
    return bubble;
  };

  AiChatWidget.prototype.appendSystem = function (text) {
    if (!this.threadEl) return;
    var div = document.createElement("div");
    div.className = "ai-chat__system";
    div.textContent = text || "";
    this.threadEl.appendChild(div);
  };

  AiChatWidget.prototype.ensureBlocksContainer = function(bubble){
    var el = bubble && bubble.querySelector(".ai-blocks");
    if (!el) { el = document.createElement("div"); el.className = "ai-blocks"; if (bubble) bubble.appendChild(el); }
    return el;
  };

  AiChatWidget.prototype.findLastAssistantBubble = function () {
    if (!this.threadEl) return null;
    var kids = Array.prototype.slice.call(this.threadEl.children || []);
    for (var i = kids.length - 1; i >= 0; i--) {
      var el = kids[i];
      if (el && el.dataset && el.dataset.role === "assistant") return el;
    }
    return null;
  };

  AiChatWidget.prototype.ensureAssistantBubble = function () {
    var b = this.findLastAssistantBubble();
    if (!b) { this.appendMessageBubble("assistant", ""); b = this.findLastAssistantBubble(); }
    return b;
  };

  AiChatWidget.prototype.ensureMsgContainer = function (bubble) {
    if (!bubble) return null;
    var msg = bubble.querySelector(".ai-msg");
    if (!msg) { msg = document.createElement("div"); msg.className = "ai-msg"; bubble.insertBefore(msg, bubble.firstChild); }
    return msg;
  };

  AiChatWidget.prototype.resetStreamBubble = function (bubble, opts) {
    bubble = bubble || this.ensureAssistantBubble();
    if (!bubble) return;
    opts = opts || {};
    var keepSpinner = !!opts.keepSpinner;
    var spinnerLabel = null;
    if (keepSpinner) {
      var labelEl = bubble.querySelector(".ai-typing__label");
      if (labelEl) spinnerLabel = labelEl.textContent;
    }
    if (bubble.dataset) { delete bubble.dataset.outputIndex; }
    var msg = this.ensureMsgContainer(bubble);
    if (msg) {
      if (msg.__mdTimer) { clearTimeout(msg.__mdTimer); msg.__mdTimer = null; }
      msg.__raw = "";
      msg.__node = null;
      msg.__tailNode = null;
      msg.textContent = "";
      msg.innerHTML = "";
    }
    var blocks = bubble.querySelector(".ai-blocks");
    if (blocks) blocks.innerHTML = "";

    // If we were already showing a spinner, re-attach it after clearing the message.
    if (keepSpinner && bubble.dataset && bubble.dataset.loading === "1") {
      this.showSpinner && this.showSpinner(bubble, spinnerLabel || "Thinking…");
    }
  };

  AiChatWidget.prototype.flushMarkdown = function (bubble) {
    if (!bubble) return;
    var msg = bubble.querySelector(".ai-msg");
    if (!msg || msg.__raw == null) return;
    if (msg.__mdTimer) { clearTimeout(msg.__mdTimer); msg.__mdTimer = null; }
    var md = msg.__raw;
    var html = ""; try { html = global.__renderMarkdown ? global.__renderMarkdown(md) : ""; } catch(_){}
    if (html && html.trim()) { msg.innerHTML = html; }
    else { if (msg.__node) msg.__node.nodeValue = md; else msg.textContent = md; }
    msg.__raw = null; msg.__node = null;
    msg.__tailNode = null;
  };

  /* Staggered blur-in reveal for AI response elements */
  AiChatWidget.prototype._revealMsg = function(bubble){
    if (!bubble) return;
    var msg = bubble.querySelector(".ai-msg");
    if (!msg) return;
    var kids = msg.children;
    if (!kids.length) return;
    msg.classList.add("ai-msg--reveal");
    var delay = 0;
    var step = 50; /* ms between each element */
    for (var i = 0; i < kids.length; i++) {
      (function(el, d){
        setTimeout(function(){
          el.classList.add("ai-blur-in");
        }, d);
      })(kids[i], delay);
      delay += step;
    }
    /* Clean up classes after all animations finish */
    setTimeout(function(){
      msg.classList.remove("ai-msg--reveal");
      for (var j = 0; j < kids.length; j++) {
        kids[j].classList.remove("ai-blur-in");
      }
    }, delay + 400);
  };

  AiChatWidget.prototype._computeSafeMarkdownSplit = function (text) {
    var safeIndex = text.length;
    var hideTail = false;

    // Hold back unclosed widget/block placeholders.
    var lastWidget = text.lastIndexOf("{{widget:");
    var lastBlock  = text.lastIndexOf("{{block:");
    var lastOpen   = Math.max(lastWidget, lastBlock);
    if (lastOpen >= 0 && text.indexOf("}}", lastOpen) === -1) {
      safeIndex = Math.min(safeIndex, lastOpen);
      hideTail = true;
    }

    // Hold back unclosed fenced code blocks.
    var fenceCount = 0;
    var lastFence = -1;
    for (var i = 0; i < text.length; i++) {
      if (text.substr(i, 3) === "```") {
        fenceCount += 1;
        lastFence = i;
        i += 2;
      }
    }
    if (fenceCount % 2 === 1 && lastFence >= 0) {
      safeIndex = Math.min(safeIndex, lastFence);
    }

    // Hold back unclosed inline code (outside fenced blocks).
    var inFence = false;
    var inlineOpenIdx = -1;
    for (var j = 0; j < text.length; j++) {
      if (text.substr(j, 3) === "```") {
        inFence = !inFence;
        j += 2;
        continue;
      }
      if (inFence) continue;
      if (text[j] === "`") {
        inlineOpenIdx = inlineOpenIdx === -1 ? j : -1;
      }
    }
    if (inlineOpenIdx !== -1) {
      safeIndex = Math.min(safeIndex, inlineOpenIdx);
    }

    if (safeIndex < 0) safeIndex = 0;
    return { index: safeIndex, hideTail: hideTail };
  };

  AiChatWidget.prototype._renderStreamingMarkdown = function (bubble) {
    if (!bubble) return;
    var msg = bubble.querySelector(".ai-msg");
    if (!msg) return;
    var raw = msg.__raw || "";
    var split = this._computeSafeMarkdownSplit(raw);
    var safeText = raw.slice(0, split.index);
    var tailText = split.hideTail ? "" : raw.slice(split.index);

    // Hide fully-formed widget/block markers during streaming; they'll be hydrated once on completion.
    safeText = safeText.replace(/\{\{(widget|block):[^}]+}}/g, " ");
    tailText = tailText.replace(/\{\{(widget|block):[^}]+}}/g, " ");

    var html = "";
    try { html = global.__renderMarkdown ? global.__renderMarkdown(safeText) : ""; } catch(_){ html = ""; }

    msg.innerHTML = html && html.trim() ? html : "";

    if (tailText) {
      var tailNode = msg.__tailNode;
      if (!tailNode || tailNode.parentNode !== msg) {
        tailNode = document.createTextNode("");
        msg.appendChild(tailNode);
        msg.__tailNode = tailNode;
      }
      tailNode.nodeValue = tailText;
    } else if (msg.__tailNode) {
      msg.__tailNode.nodeValue = "";
    }
  };

  AiChatWidget.prototype._scheduleMarkdownRender = function (bubble) {
    var msg = bubble && bubble.querySelector(".ai-msg");
    if (!msg) return;
    if (msg.__mdTimer) return;
    var self = this;
    msg.__mdTimer = setTimeout(function(){
      msg.__mdTimer = null;
      self._renderStreamingMarkdown(bubble);
    }, 180);
  };

  AiChatWidget.prototype.handleToken = function (token, outputIndex) {
    if (!this.threadEl) return;
    var bubble = this.ensureAssistantBubble(); if (!bubble) return;

    // If the model switches to a new output index mid-stream, reset the bubble
    // so earlier "thinking" fragments don't flash before the final answer.
    var idx = parseInt(outputIndex, 10);
    if (!isNaN(idx)) {
      var prevIdx = bubble.dataset.outputIndex ? parseInt(bubble.dataset.outputIndex, 10) : null;
      if (prevIdx === null || idx > prevIdx) {
        bubble.dataset.outputIndex = String(idx);
        var resetMsg = this.ensureMsgContainer(bubble);
        if (resetMsg) {
          resetMsg.__raw = "";
          resetMsg.__node = null;
          resetMsg.textContent = "";
          resetMsg.innerHTML = "";
        }
        var resetBlocks = bubble.querySelector(".ai-blocks");
        if (resetBlocks) resetBlocks.innerHTML = "";
      } else if (idx < prevIdx) {
        return;
      }
    }

    // first token => fade spinner
    this.fadeSpinner(bubble);

    var msg = this.ensureMsgContainer(bubble); if (!msg) return;
    msg.__raw = (msg.__raw || "") + String(token);

    // Guardrails: fix squished numbers in-stream so "remove1–2" -> "remove 1–2" and "Safety):100%" -> "Safety): 100%".
    msg.__raw = msg.__raw
      .replace(/([A-Za-z])(\d)/g, "$1 $2")
      .replace(/([):])(\d)/g, "$1 $2");

    this._scheduleMarkdownRender(bubble);

    // Do not auto-scroll during streaming; only show arrow if user is not near bottom
    if (this._streamingActive && !this.isNearBottom()) {
      this.showScrollToBottom(true);
    }
  };


  AiChatWidget.prototype.chartKeyFromParams = function (p) {
    if (!p) return null;
    try {
      var metric = (p.metric || "").toString();
      var cat = (p.category || "").toString();
      var s = (p.start_date || "").toString();
      var e = (p.end_date || "").toString();
      var mids = (p.metric_ids || []).slice().sort().join("-");
      var smids = (p.submetric_ids || []).slice().sort().join("-");
      var scids = (p.subcategory_ids || []).slice().sort().join("-");
      return [metric, cat, s, e, mids, smids, scids].join("|");
    } catch(_) { return null; }
  };

  /* ---- mount ---- */
  AiChatWidget.mount = function(target){
    var el = (typeof target === "string") ? document.querySelector(target) : target;
    if (!el) return null;
    var w = new AiChatWidget(el); w.init(); return w;
  };

  document.addEventListener("DOMContentLoaded", function(){
    var nodes = document.querySelectorAll('[data-controller="ai-chat-widget"], .js-ai-chat-widget');
    for (var i=0; i<nodes.length; i++){ if (!nodes[i]._aiChatWidget) nodes[i]._aiChatWidget = AiChatWidget.mount(nodes[i]); }
  });

  /* ---------------------------------------------------------------
     Easter egg: type "replay" anywhere on the page (outside of input
     fields) and the onboarding flow will be reset + relaunched. Makes
     prototype demos easy to re-trigger without clearing localStorage
     by hand. 2-second rolling buffer so stray keystrokes don't match.
     --------------------------------------------------------------- */
  (function(){
    var KEYWORD = "replay";
    var buffer = "";
    var resetTimer = null;

    function resetOnboarding(){
      try { localStorage.removeItem("clara_onboarding_completed_v1"); } catch(_) {}

      var node = document.querySelector('[data-controller="ai-chat-widget"], .js-ai-chat-widget');
      var widget = node && node._aiChatWidget;
      if (!widget) return;

      // Find the onboarding conversation in the loaded list
      var convs = widget.conversations || [];
      var onboardingId = null;
      for (var i = 0; i < convs.length; i++) {
        if (convs[i].title === AiChatWidget.ONBOARDING_TITLE) {
          onboardingId = convs[i].id;
          break;
        }
      }
      if (!onboardingId) return;

      // Wipe client-side scripted history so the state machine starts over
      if (widget._dummyConvos && widget._dummyConvos[onboardingId]) {
        delete widget._dummyConvos[onboardingId];
      }
      widget._pendingOnboardingGreeting = null;
      widget._lastDummyIdx = -1;

      // Re-open the conversation so it re-renders the landing fresh
      if (widget.openConversation) widget.openConversation(onboardingId);

      if (window.showToast) {
        window.showToast("Onboarding reset — replaying now", null, false);
      } else if (window.toast) {
        window.toast("Onboarding reset — replaying now", "success");
      }
    }

    document.addEventListener("keydown", function(e){
      // Ignore when typing inside inputs / textareas / contenteditable
      var tag = (e.target && e.target.tagName || "").toLowerCase();
      if (tag === "input" || tag === "textarea" || (e.target && e.target.isContentEditable)) return;
      // Only single-character keys matter for matching
      if (!e.key || e.key.length !== 1) return;

      buffer += e.key.toLowerCase();
      if (buffer.length > KEYWORD.length) buffer = buffer.slice(-KEYWORD.length);

      if (resetTimer) clearTimeout(resetTimer);
      resetTimer = setTimeout(function(){ buffer = ""; }, 2000);

      if (buffer === KEYWORD) {
        buffer = "";
        resetOnboarding();
      }
    });
  })();

  global.AiChatWidget = AiChatWidget;
})(window);
</script>
