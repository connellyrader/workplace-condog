<script>
/* ============================== Chat Widget — Core (floating sidebar + row menus; multi menu buttons; original cable binding; spinner helpers) ============================== */
(function (global) {
  function qs(root, sel){ return root.querySelector(sel); }
  function qsa(root, sel){ return Array.prototype.slice.call(root.querySelectorAll(sel)); }
  function csrf(){ var m=document.querySelector('meta[name="csrf-token"]'); return m && m.content; }

  function askConfirm(opts) {
    // Non-destructive confirm
    return notice(opts.body || "", {
      title: opts.title || "Notice",
      confirmLabel: opts.confirmText || "Continue",
      cancelLabel: opts.cancelText || "Cancel"
    });
  }

  function askDanger(opts) {
    // Destructive confirm
    return warning(opts.body || "", {
      title: opts.title || "Warning",
      confirmLabel: opts.confirmText || "Delete",
      cancelLabel: opts.cancelText || "Cancel"
    });
  }

  function AiChatWidget(root){
    this.root = root;
    this.conversations = [];
    this.currentConversationId = null;
    this.sidebarOpen = false;
    this.subscription = null;

    var ds = root.dataset || {};
    this.listUrl   = ds.aiChatWidgetListUrlValue   || ds.listUrl;
    this.showUrl   = ds.aiChatWidgetShowUrlValue   || ds.showUrl;
    this.createUrl = ds.aiChatWidgetCreateUrlValue || ds.createUrl;
    this.cableUrl  = ds.aiChatWidgetCableUrlValue  || ds.cableUrl || "/cable";

    if (ds.aiChatWidgetConversationListSelectorValue) {
      this.conversationListEl = document.querySelector(ds.aiChatWidgetConversationListSelectorValue);
    } else {
      this.conversationListEl = qs(root,'[data-ai-chat-widget-target="conversationList"]') || qs(root, ".ai-chat__list");
    }
    this.threadEl           = qs(root,'[data-ai-chat-widget-target="thread"]')           || qs(root, ".ai-chat__thread");
    this.inputEl            = qs(root,'[data-ai-chat-widget-target="input"]')            || qs(root, ".ai-chat__input");
    this.sendBtnEl          = qs(root,'[data-ai-chat-widget-target="sendBtn"]')          || qs(root, ".ai-chat__send");
    this.placeholderCyclerEl = qs(root, ".ai-chat__placeholder-cycler");
    this.scrollBtnEl        = qs(root, ".ai-chat__scroll-bottom");
    this.composerForm       = qs(root, ".ai-chat__composer") || qs(root, "form");

    this._streamingActive   = false;

    /* persistent UI */
    this.sidebarToggleBtns  = qsa(root, ".ai-chat__menu-topbar-toggle");
    this.sidebarCloseBtn    = qs(root, ".ai-chat__sidebar-close");
    this.topbarNewBtn       = qs(root, ".ai-chat__topbar-new");
    this.scrimEl            = qs(root, ".ai-chat__scrim");
    this.titleEl            = qs(root, '[data-ai-chat-widget-target="conversationTitle"]');
    this._navNewBtns       = [];

    /* optional legacy buttons */
    this.hamburgerBtn       = qs(root, ".ai-chat__hamburger");
    this.newBtn             = qs(root, ".ai-chat__new");
  }

  /* ---- scrolling ---- */
  AiChatWidget.prototype._scrollContainer = function(){
    if (!this.threadEl) return null;
    var wrap = this.threadEl.parentElement;
    return (wrap && wrap.classList.contains("ai-chat__thread-wrap")) ? wrap : this.threadEl;
  };

  AiChatWidget.prototype.isNearBottom = function(){
    var el = this._scrollContainer();
    if (!el) return true;
    var threshold = 48;
    return (el.scrollHeight - (el.scrollTop + el.clientHeight)) <= threshold;
  };

  AiChatWidget.prototype.showScrollToBottom = function(show){
    if (!this.scrollBtnEl) return;
    this.scrollBtnEl.classList.toggle("is-visible", !!show);
    this.scrollBtnEl.setAttribute("aria-hidden", show ? "false" : "true");
  };

  AiChatWidget.prototype._updateStickyState = function(){
    var atBottom = this.isNearBottom();
    if (this._streamingActive && !atBottom) {
      this.showScrollToBottom(true);
    } else {
      this.showScrollToBottom(false);
    }
  };

  AiChatWidget.prototype._scroll = function(){
    var el = this._scrollContainer();
    if (!el) return;
    el.scrollTop = el.scrollHeight;
    this.showScrollToBottom(false);
  };
  AiChatWidget.prototype.scrollToBottom = function(){ this._scroll(); };

  /* ---- cycling placeholder (main chat composer only) ---- */
  AiChatWidget.prototype._stopPlaceholderCycle = function(){
    if (this._placeholderTimer) {
      clearTimeout(this._placeholderTimer);
      this._placeholderTimer = null;
    }
    if (this.placeholderCyclerEl) {
      this.placeholderCyclerEl.classList.remove("ai-chat__placeholder-cycler--exit");
      this.placeholderCyclerEl.classList.remove("ai-chat__placeholder-cycler--snap-out");
    }
  };

  AiChatWidget.prototype._placeholderCyclerVisible = function(){
    return this.inputEl && !this.inputEl.value.trim() && document.activeElement !== this.inputEl;
  };

  AiChatWidget.prototype._schedulePlaceholderAdvance = function(){
    var self = this;
    if (!this.placeholderCyclerEl) return;
    if (this._placeholderTimer) clearTimeout(this._placeholderTimer);
    if (!this._placeholderCyclerVisible()) return;
    this._placeholderTimer = setTimeout(function(){
      self._placeholderTimer = null;
      if (!self._placeholderCyclerVisible()) return;
      self._advancePlaceholderPhrase();
    }, 3000);
  };

  AiChatWidget.prototype._advancePlaceholderPhrase = function(){
    var self = this;
    var el = this.placeholderCyclerEl;
    if (!el || !this._placeholderPhrases || !this._placeholderPhrases.length) return;
    if (!this._placeholderCyclerVisible()) {
      this._schedulePlaceholderAdvance();
      return;
    }

    var settled = false;
    var finish = function(){
      if (settled) return;
      settled = true;
      el.removeEventListener("transitionend", onEnd);
      if (!el.parentNode || !self.placeholderCyclerEl) return;

      el.classList.add("ai-chat__placeholder-cycler--snap-out");
      el.classList.remove("ai-chat__placeholder-cycler--exit");
      self._placeholderIndex = (self._placeholderIndex + 1) % self._placeholderPhrases.length;
      el.textContent = self._placeholderPhrases[self._placeholderIndex];
      void el.offsetWidth;
      el.classList.remove("ai-chat__placeholder-cycler--snap-out");

      self._schedulePlaceholderAdvance();
    };

    var onEnd = function(e){
      if (!e || (e.propertyName !== "opacity" && e.propertyName !== "filter")) return;
      finish();
    };

    el.addEventListener("transitionend", onEnd);
    el.classList.add("ai-chat__placeholder-cycler--exit");
    setTimeout(finish, 480);
  };

  AiChatWidget.prototype._syncPlaceholderCycler = function(){
    if (!this.placeholderCyclerEl || !this.inputEl) return;
    var empty = !this.inputEl.value.trim();
    var focused = document.activeElement === this.inputEl;
    var show = empty && !focused;
    this.placeholderCyclerEl.classList.toggle("is-hidden", !show);
    if (!show) {
      this._stopPlaceholderCycle();
    } else if (!this._placeholderTimer) {
      this._schedulePlaceholderAdvance();
    }
  };

  /* ---- lifecycle ---- */
  AiChatWidget.prototype.init = function(){
    /* ✅ keep EXACT working cable logic */
    var useAC = (global.ActionCable && typeof global.ActionCable.createConsumer === "function");
    var Cable = useAC ? { createConsumer: global.ActionCable.createConsumer.bind(global.ActionCable) }
                      : global.SimpleCable;

    this.consumer = Cable && typeof Cable.createConsumer === "function" ? Cable.createConsumer(this.cableUrl) : null;
    if (!this.consumer || !this.consumer.subscriptions || typeof this.consumer.subscriptions.create !== "function") {
      console.error("[AiChatWidget] Cable consumer missing subscriptions.create"); return;
    }

    /* events */
    if (this.composerForm){
      var self = this;
      this._onSubmit = this.send ? this.send.bind(this) : function(e){ e && e.preventDefault && e.preventDefault(); };
      this.composerForm.addEventListener("submit", this._onSubmit);
    }

    // Enter to send (Shift+Enter = newline)
    if (this.inputEl) {
      var selfInput = this;
      this._onInputKeydown = function(e){
        if (e.key === "Enter" && !e.shiftKey && !e.metaKey && !e.ctrlKey && !e.altKey) {
          e.preventDefault();
          // Don't try to send if already disabled (still streaming)
          if (selfInput.sendBtnEl && selfInput.sendBtnEl.disabled) return;
          if (selfInput.composerForm) {
            selfInput.composerForm.dispatchEvent(
              new Event("submit", { bubbles: true, cancelable: true })
            );
          }
        }
      };
      this.inputEl.addEventListener("keydown", this._onInputKeydown);

      // Auto-resize textarea (expands upward via flex-end alignment)
      this._resizeInput = function(){
        var el = selfInput.inputEl;
        if (!el) return;
        el.style.height = "0";
        el.style.height = Math.min(el.scrollHeight, 200) + "px";
      };
      this.inputEl.addEventListener("input", this._resizeInput);
      this.inputEl.addEventListener("focus", this._resizeInput);
      this._resizeInput();

      // Toggle Send button ready state based on input content
      this._updateSendReady = function(){
        var hasContent = selfInput.inputEl && selfInput.inputEl.value.trim().length > 0;
        if (selfInput.sendBtnEl) {
          selfInput.sendBtnEl.classList.toggle("is-ready", !!hasContent);
        }
      };
      this.inputEl.addEventListener("input", this._updateSendReady);
      this.inputEl.addEventListener("focus", this._updateSendReady);
      this.inputEl.addEventListener("blur", this._updateSendReady);
      this._updateSendReady();

      if (this.placeholderCyclerEl) {
        var selfPh = this;
        this._placeholderPhrases = [
          "How is team morale trending...",
          "What drives engagement here...",
          "Compare groups on alignment...",
          "Explain this week's culture shift...",
          "Which metrics changed most...",
          "What's hurting our alignment...",
          "Summarize recent culture signals...",
          "Why did execution risk rise...",
          "Show psychological safety trends...",
          "What improved since last month...",
          "How stressed is the team...",
          "Where is conflict showing up..."
        ];
        this._placeholderIndex = 0;
        this._placeholderTimer = null;
        this.placeholderCyclerEl.textContent = this._placeholderPhrases[0];
        this._onPlaceholderCyclerVisibility = function(){
          selfPh._syncPlaceholderCycler();
        };
        this.inputEl.addEventListener("focus", this._onPlaceholderCyclerVisibility);
        this.inputEl.addEventListener("blur", this._onPlaceholderCyclerVisibility);
        this.inputEl.addEventListener("input", this._onPlaceholderCyclerVisibility);
        this._syncPlaceholderCycler();
      }
    }

    var selfMenu = this;
    if (this.sidebarToggleBtns && this.sidebarToggleBtns.length){
      this._onSidebarToggle = function(e){ if(e&&e.preventDefault) e.preventDefault(); selfMenu.setSidebarOpen(!selfMenu.isSidebarOpen()); };
      this.sidebarToggleBtns.forEach(function(btn){ btn.addEventListener("click", selfMenu._onSidebarToggle); });
    }
    if (this.sidebarCloseBtn){
      this._onSidebarClose = function(e){ if(e&&e.preventDefault) e.preventDefault(); selfMenu.setSidebarOpen(false); };
      this.sidebarCloseBtn.addEventListener("click", this._onSidebarClose);
    }
    if (this.topbarNewBtn){
      this._onTopbarNew = function(e){
        if(e&&e.preventDefault) e.preventDefault();
        selfMenu.startNewConversation && selfMenu.startNewConversation();
        selfMenu.setSidebarOpen(false);
      };
      this.topbarNewBtn.addEventListener("click", this._onTopbarNew);
    }

    var selfNavNew = this;
    this._onNavNew = function(e){
      if (e && e.preventDefault) e.preventDefault();
      selfNavNew.startNewConversation && selfNavNew.startNewConversation();
      selfNavNew.setSidebarOpen && selfNavNew.setSidebarOpen(false);
    };
    qsa(document, ".js-clara-nav-new").forEach(function(btn){
      btn.addEventListener("click", selfNavNew._onNavNew);
      selfNavNew._navNewBtns.push(btn);
    });

    if (this.scrimEl){
      var selfScrim = this;
      this._onScrim = function(e){ if(e&&e.preventDefault) e.preventDefault(); selfScrim.setSidebarOpen(false); };
      this.scrimEl.addEventListener("click", this._onScrim);
    }
    if (this.hamburgerBtn){
      var selfHam = this;
      this._onToggle = function(e){ if(e&&e.preventDefault) e.preventDefault(); selfHam.setSidebarOpen(!selfHam.isSidebarOpen()); };
      this.hamburgerBtn.addEventListener("click", this._onToggle);
    }
    if (this.newBtn){
      var selfNew = this;
      this._onNew = function(e){ if(e&&e.preventDefault) e.preventDefault(); selfNew.startNewConversation && selfNew.startNewConversation(); selfNew.setSidebarOpen(false); };
      this.newBtn.addEventListener("click", this._onNew);
    }

    // Scroll tracking + jump-to-bottom
    var scrollTarget = this._scrollContainer && this._scrollContainer();
    if (scrollTarget) {
      var selfScroll = this;
      this._onThreadScroll = function(){ selfScroll._updateStickyState && selfScroll._updateStickyState(); };
      scrollTarget.addEventListener("scroll", this._onThreadScroll, { passive: true });
    }
    if (this.scrollBtnEl) {
      var selfJump = this;
      this._onScrollBtn = function(e){
        if (e && e.preventDefault) e.preventDefault();
        selfJump.scrollToBottom && selfJump.scrollToBottom();
        selfJump.showScrollToBottom && selfJump.showScrollToBottom(false);
      };
      this.scrollBtnEl.addEventListener("click", this._onScrollBtn);
    }

    /* conversation list delegation (row click / kebab / popover actions) */
    var selfList = this;
    if (this.conversationListEl){
      this._onListClick = function(e){ selfList.onListClick && selfList.onListClick(e); };
      this.conversationListEl.addEventListener("click", this._onListClick);
    }
    var selfDoc = this;
    this._onDocClick = function(e){ selfDoc.onDocClick && selfDoc.onDocClick(e); };
    document.addEventListener("click", this._onDocClick);

    /* start closed */
    this.setSidebarOpen(false);

    this.loadConversations().catch(function(e){ console.error("[AiChatWidget] loadConversations failed:", e); });
  };

  AiChatWidget.prototype.destroy = function(){
    this._stopPlaceholderCycle && this._stopPlaceholderCycle();
    if (this.inputEl && this._onPlaceholderCyclerVisibility) {
      this.inputEl.removeEventListener("focus", this._onPlaceholderCyclerVisibility);
      this.inputEl.removeEventListener("blur", this._onPlaceholderCyclerVisibility);
      this.inputEl.removeEventListener("input", this._onPlaceholderCyclerVisibility);
    }

    if (this.subscription && this.subscription.unsubscribe) this.subscription.unsubscribe();
    if (this.composerForm && this._onSubmit) this.composerForm.removeEventListener("submit", this._onSubmit);

    if (this.inputEl && this._onInputKeydown) {this.inputEl.removeEventListener("keydown", this._onInputKeydown);}
    if (this.sidebarToggleBtns && this._onSidebarToggle) {
      this.sidebarToggleBtns.forEach(function(btn){ btn.removeEventListener("click", this._onSidebarToggle); }, this);
    }
    if (this.sidebarCloseBtn && this._onSidebarClose) this.sidebarCloseBtn.removeEventListener("click", this._onSidebarClose);
    if (this.topbarNewBtn && this._onTopbarNew) this.topbarNewBtn.removeEventListener("click", this._onTopbarNew);
    var selfDn = this;
    if (this._onNavNew && this._navNewBtns && this._navNewBtns.length) {
      this._navNewBtns.forEach(function(btn){ btn.removeEventListener("click", selfDn._onNavNew); });
      this._navNewBtns = [];
    }
    if (this.scrimEl && this._onScrim) this.scrimEl.removeEventListener("click", this._onScrim);
    if (this.hamburgerBtn && this._onToggle) this.hamburgerBtn.removeEventListener("click", this._onToggle);
    if (this.newBtn && this._onNew) this.newBtn.removeEventListener("click", this._onNew);

    if (this.conversationListEl && this._onListClick) this.conversationListEl.removeEventListener("click", this._onListClick);
    if (this._onDocClick) document.removeEventListener("click", this._onDocClick);
    if (this.threadEl && this._onThreadScroll) this.threadEl.removeEventListener("scroll", this._onThreadScroll);
    if (this.scrollBtnEl && this._onScrollBtn) this.scrollBtnEl.removeEventListener("click", this._onScrollBtn);
  };

  /* ---- sidebar control ---- */
  AiChatWidget.prototype.isSidebarOpen = function(){ return this.root.classList.contains("ai-chat--sidebar-open"); };
  AiChatWidget.prototype.setSidebarOpen = function(open){
    this.sidebarOpen = !!open;
    this.root.classList.toggle("ai-chat--sidebar-open", this.sidebarOpen);
    var expanded = String(this.sidebarOpen);
    if (this.sidebarToggleBtns && this.sidebarToggleBtns.length){
      this.sidebarToggleBtns.forEach(function(btn){ btn.setAttribute("aria-expanded", expanded); });
    }
    if (this.sidebarCloseBtn){
      this.sidebarCloseBtn.setAttribute("aria-expanded", expanded);
    }
  };
  AiChatWidget.prototype.toggleSidebar = function(e){ if (e && e.preventDefault) e.preventDefault(); this.setSidebarOpen(!this.isSidebarOpen()); };
  AiChatWidget.prototype.closeSidebar  = function(e){ if (e && e.preventDefault) e.preventDefault(); this.setSidebarOpen(false); };

  /* ---- REST ---- */
  AiChatWidget.prototype.updateConversationTitle = function(title){
    if (!this.titleEl) return;
    var t = (title || "").toString().trim();
    this.titleEl.textContent = t || " ";
  };

  AiChatWidget.prototype.loadConversations = async function(){
    var res = await fetch(this.listUrl, { headers: { "Accept":"application/json" } });
    if(!res.ok) throw new Error("Failed to load conversations");
    this.conversations = await res.json();
    if (this.conversations && this.conversations.length) {
      this._introTitleConsumed = true;
    }
    this.renderConversationList();
    if (this.conversations.length) { this.openConversation && this.openConversation(this.conversations[0].id); }
    else { this.startNewConversation && this.startNewConversation(); }
  };

  AiChatWidget.prototype.createConversation = async function(){
    var isHome = (this.root.dataset.aiChatWidgetLayoutValue === "home");
    var title = "New conversation";
    if (isHome && !this._introTitleConsumed) {
      title = "Introduce yourself";
      this._introTitleConsumed = true;
    }
    var payload = { title: title };

    var res = await fetch(this.createUrl, {
      method: "POST",
      headers: { "Accept":"application/json", "Content-Type":"application/json", "X-CSRF-Token": csrf() },
      body: JSON.stringify(payload)
    });
    if(!res.ok) throw new Error("Failed to create conversation");
    var conv = await res.json();
    this.conversations.unshift(conv);
    this.renderConversationList();
    if (this.openConversation) await this.openConversation(conv.id);
  };

  /* Show the landing page without creating a conversation.
     A real conversation will be created on the user's first send. */
  AiChatWidget.prototype.startNewConversation = function(){
    if (this.subscription && this.subscription.unsubscribe) {
      try { this.subscription.unsubscribe(); } catch(_) {}
      this.subscription = null;
    }
    this.currentConversationId = null;
    this.renderConversationList();

    if (this.threadEl) this.threadEl.innerHTML = "";

    this._streamingActive = false;
    if (this.hideAnalyzingBar) this.hideAnalyzingBar();
    if (this.renderEmptyIntro) this.renderEmptyIntro();

    this._scroll && this._scroll();
    if (this.showScrollToBottom) this.showScrollToBottom(false);
  };

  /* rows with kebab (⋯) + popover (Delete) */
  AiChatWidget.prototype.renderConversationList = function(){
    if(!this.conversationListEl) return;
    var self = this;
    this.conversationListEl.innerHTML = "";
    this.conversations.forEach(function(c){
      var row = document.createElement("div");
      row.className = "ai-chat__list-item" + (c.id === self.currentConversationId ? " is-active" : "");
      row.dataset.id = c.id;

      var title = document.createElement("div");
      title.className = "ai-chat__list-title";
      title.textContent = c.title || c.name || ("Conversation #" + c.id);

      var menu = document.createElement("button");
      menu.className = "ai-chat__row-menu";
      menu.setAttribute("aria-haspopup","menu");
      menu.setAttribute("aria-expanded","false");
      menu.innerText = "⋯";

      var pop = document.createElement("div");
      pop.className = "ai-chat__row-popover";
      pop.setAttribute("role","menu");

      var del = document.createElement("button");
      del.className = "ai-chat__row-act";
      del.dataset.action = "delete";
      del.textContent = "Delete conversation";

      pop.appendChild(del);
      row.appendChild(title);
      row.appendChild(menu);
      row.appendChild(pop);
      self.conversationListEl.appendChild(row);
    });
  };

  /* ---- row menu interactions ---- */
  AiChatWidget.prototype.onListClick = function(e){
    var row = e.target && e.target.closest && e.target.closest(".ai-chat__list-item");
    if (!row) return;

    // kebab toggle
    if (e.target.closest(".ai-chat__row-menu")) {
      e.preventDefault();
      var pop = row.querySelector(".ai-chat__row-popover");
      var btn = row.querySelector(".ai-chat__row-menu");
      var isOpen = pop.classList.contains("is-open");
      this.closeAllRowMenus();
      if (!isOpen) {
        pop.classList.add("is-open");
        btn && btn.setAttribute("aria-expanded","true");
      }
      return;
    }

    // popover actions
    var act = e.target.closest(".ai-chat__row-act");
    if (act) {
      e.preventDefault();
      var id = parseInt(row.dataset.id, 10);
      var title = (row.querySelector(".ai-chat__list-title") || {}).textContent || ("Conversation #"+id);
      if (act.dataset.action === "delete") {
        this.closeAllRowMenus();
        var self = this;
        askDanger({
          title: "Delete conversation?",
          body: 'This will permanently remove “' + title + '”. This action cannot be undone.',
          confirmText: "Delete conversation",
          cancelText: "Cancel"
        }).then(function(ok){
          if (!ok) return;
          if (self.deleteConversation) self.deleteConversation(id);
        });
      }
      return;
    }

    // open convo + close sidebar
    this.openConversation && this.openConversation(parseInt(row.dataset.id, 10));
    this.closeSidebar();
  };

  AiChatWidget.prototype.onDocClick = function(e){
    if (!(e.target && (e.target.closest(".ai-chat__row-popover") || e.target.closest(".ai-chat__row-menu")))) {
      this.closeAllRowMenus();
    }
  };

  AiChatWidget.prototype.closeAllRowMenus = function(){
    var pops = this.conversationListEl ? this.conversationListEl.querySelectorAll(".ai-chat__row-popover.is-open") : [];
    Array.prototype.forEach.call(pops, function(p){ p.classList.remove("is-open"); });
    var btns = this.conversationListEl ? this.conversationListEl.querySelectorAll(".ai-chat__row-menu[aria-expanded='true']") : [];
    Array.prototype.forEach.call(btns, function(b){ b.setAttribute("aria-expanded","false"); });
  };

  /* ---- Unicode braille spinners (from unicode-animations) ---- */
  AiChatWidget._brailleSpinners = {
    braille:      { frames: ["\u280B","\u2819","\u2839","\u2838","\u283C","\u2834","\u2826","\u2827","\u2807","\u280F"], interval: 80 },


    orbit:        { frames: (function(){
      var W=2,H=4,path=[[0,0],[0,1],[1,1],[2,1],[3,1],[3,0],[2,0],[1,0]],frames=[];
      function g2b(grid){var rows=grid.length,cols=grid[0]?grid[0].length:0,cc=Math.ceil(cols/2),r="",DOTS=[[1,8],[2,16],[4,32],[64,128]];for(var c=0;c<cc;c++){var code=10240;for(var rr=0;rr<4&&rr<rows;rr++){for(var d=0;d<2;d++){var col=c*2+d;if(col<cols&&grid[rr]&&grid[rr][col])code|=DOTS[rr][d]}}r+=String.fromCodePoint(code)}return r}
      function mg(r,c){if(r<=0||c<=0)return[];return Array.from({length:r},function(){return Array(c).fill(false)})}
      for(var i=0;i<path.length;i++){var g=mg(H,W);g[path[i][0]][path[i][1]]=true;var t1=(i-1+path.length)%path.length;g[path[t1][0]][path[t1][1]]=true;frames.push(g2b(g))}return frames;
    })(), interval: 100 },
    diagswipe:    { frames: (function(){
      var W=4,H=4,frames=[],DOTS=[[1,8],[2,16],[4,32],[64,128]];
      function g2b(grid){var rows=grid.length,cols=grid[0]?grid[0].length:0,cc=Math.ceil(cols/2),r="";for(var c=0;c<cc;c++){var code=10240;for(var rr=0;rr<4&&rr<rows;rr++){for(var d=0;d<2;d++){var col=c*2+d;if(col<cols&&grid[rr]&&grid[rr][col])code|=DOTS[rr][d]}}r+=String.fromCodePoint(code)}return r}
      function mg(r,c){return Array.from({length:r},function(){return Array(c).fill(false)})}
      var maxDiag=W+H-2;
      for(var d=0;d<=maxDiag;d++){var g=mg(H,W);for(var r=0;r<H;r++){for(var c=0;c<W;c++){if(r+c<=d)g[r][c]=true}}frames.push(g2b(g))}
      var full=mg(H,W);for(var r=0;r<H;r++)for(var c=0;c<W;c++)full[r][c]=true;frames.push(g2b(full));
      for(var d=0;d<=maxDiag;d++){var g=mg(H,W);for(var r=0;r<H;r++){for(var c=0;c<W;c++){if(r+c>d)g[r][c]=true}}frames.push(g2b(g))}
      frames.push(g2b(mg(H,W)));return frames;
    })(), interval: 60 },
    breathe:      { frames: (function(){
      var stages=[[],[[1,0]],[[0,1],[2,0]],[[0,0],[1,1],[3,0]],[[0,0],[1,1],[2,0],[3,1]],[[0,0],[0,1],[1,1],[2,0],[3,1]],[[0,0],[0,1],[1,0],[2,1],[3,0],[3,1]],[[0,0],[0,1],[1,0],[1,1],[2,0],[3,0],[3,1]],[[0,0],[0,1],[1,0],[1,1],[2,0],[2,1],[3,0],[3,1]]];
      var DOTS=[[1,8],[2,16],[4,32],[64,128]];
      function g2b(grid){var rows=grid.length,cols=grid[0]?grid[0].length:0,cc=Math.ceil(cols/2),r="";for(var c=0;c<cc;c++){var code=10240;for(var rr=0;rr<4&&rr<rows;rr++){for(var d=0;d<2;d++){var col=c*2+d;if(col<cols&&grid[rr]&&grid[rr][col])code|=DOTS[rr][d]}}r+=String.fromCodePoint(code)}return r}
      function mg(r,c){return Array.from({length:r},function(){return Array(c).fill(false)})}
      var seq=stages.concat(stages.slice().reverse().slice(1)),frames=[];
      for(var i=0;i<seq.length;i++){var g=mg(4,2);for(var j=0;j<seq[i].length;j++){g[seq[i][j][0]][seq[i][j][1]]=true}frames.push(g2b(g))}return frames;
    })(), interval: 100 }
  };

  /* Pick a random spinner each time. Only includes single-braille-character
     (2 columns wide) spinners with coherent motion, so the dot pattern reads
     as an animation rather than a shape that changes height frame-to-frame.
     `braille` (the generic char-based default) is excluded because its frames
     vary between 3- and 4-row patterns which looks off next to the text.
     Wider spinners like `diagswipe` are still defined for the analyzing bar
     but excluded here. */
  AiChatWidget._spinnerNames = ["orbit", "breathe"];
  AiChatWidget._randomSpinner = function(){
    var names = AiChatWidget._spinnerNames;
    return AiChatWidget._brailleSpinners[names[Math.floor(Math.random() * names.length)]];
  };

  /* ---- spinner helpers ---- */
  AiChatWidget.prototype.showSpinner = function(bubble, label){
    var msg = this.ensureMsgContainer(bubble); if (!msg) return;
    this.removeSpinner(bubble);
    var wrap = document.createElement("div");
    wrap.className = "ai-typing";
    wrap.setAttribute("role","status");
    wrap.setAttribute("aria-live","polite");

    /* Build inner HTML: braille spinner + dots + label */
    var html = '<span class="ai-typing__braille" aria-hidden="true"></span>' +
               '<span class="ai-typing__dot"></span><span class="ai-typing__dot"></span><span class="ai-typing__dot"></span>' +
               (label ? ('<span class="ai-typing__label ai-typing__label--shimmer">'+String(label)+'</span>') : '');
    wrap.innerHTML = html;
    bubble.dataset.loading = "1";
    msg.appendChild(wrap);

    /* Start braille animation */
    var brailleEl = wrap.querySelector(".ai-typing__braille");
    var spinnerData = AiChatWidget._randomSpinner();
    var frameIdx = 0;
    brailleEl.textContent = spinnerData.frames[0];
    var timerId = setInterval(function(){
      frameIdx = (frameIdx + 1) % spinnerData.frames.length;
      brailleEl.textContent = spinnerData.frames[frameIdx];
    }, spinnerData.interval);
    wrap._brailleTimer = timerId;
  };
  AiChatWidget.prototype.removeSpinner = function(bubble){
    bubble = bubble || this.findLastAssistantBubble();
    if (!bubble) return;
    delete bubble.dataset.loading;
    var t = bubble.querySelector(".ai-typing");
    if (t) {
      if (t._brailleTimer) clearInterval(t._brailleTimer);
      if (t.parentNode) t.parentNode.removeChild(t);
    }
  };
  AiChatWidget.prototype.fadeSpinner = function(bubble){
    bubble = bubble || this.findLastAssistantBubble();
    if (!bubble) return;
    delete bubble.dataset.loading;
    var t = bubble.querySelector(".ai-typing");
    if (!t) return;
    t.classList.add("ai-typing--fade");
    var timer = t._brailleTimer;
    setTimeout(function(){
      if (timer) clearInterval(timer);
      if (t && t.parentNode) t.parentNode.removeChild(t);
    }, 450);
  };

  /* ---- Analyzing bar (appended above composer input) ---- */
  AiChatWidget.prototype.showAnalyzingBar = function(){
    if (this._analyzingBar) return; /* already showing */
    var inputWrap = this.composerForm && this.composerForm.querySelector(".ai-chat__input-wrap");
    if (!inputWrap) return;

    var bar = document.createElement("div");
    bar.className = "ai-chat__analyzing-bar";

    /* Left side: spinner + label */
    var left = document.createElement("div");
    left.className = "ai-chat__analyzing-left";

    var spinnerEl = document.createElement("span");
    spinnerEl.className = "ai-chat__analyzing-spinner";
    var scanData = AiChatWidget._brailleSpinners.diagswipe;
    var frameIdx = 0;
    spinnerEl.textContent = scanData.frames[0];
    var spinnerTimer = setInterval(function(){
      frameIdx = (frameIdx + 1) % scanData.frames.length;
      spinnerEl.textContent = scanData.frames[frameIdx];
    }, scanData.interval);

    var label = document.createElement("span");
    label.className = "ai-chat__analyzing-label";
    label.textContent = "Analyzing Slack messages\u2026";

    left.appendChild(spinnerEl);
    left.appendChild(label);

    /* Right side: count-up timer */
    var timerEl = document.createElement("span");
    timerEl.className = "ai-chat__analyzing-timer";
    var seconds = 0;
    function formatTime(s){
      if (s < 60) return s + "s";
      return Math.floor(s / 60) + "m " + (s % 60) + "s";
    }
    timerEl.textContent = formatTime(seconds);
    var countTimer = setInterval(function(){
      seconds++;
      timerEl.textContent = formatTime(seconds);
    }, 1000);

    bar.appendChild(left);
    bar.appendChild(timerEl);

    /* Insert bar as first child of input-wrap (above the textarea) */
    inputWrap.insertBefore(bar, inputWrap.firstChild);

    this._analyzingBar = bar;
    this._analyzingBar._spinnerTimer = spinnerTimer;
    this._analyzingBar._countTimer = countTimer;
  };

  AiChatWidget.prototype.hideAnalyzingBar = function(){
    var bar = this._analyzingBar;
    if (!bar) return;
    if (bar._spinnerTimer) clearInterval(bar._spinnerTimer);
    if (bar._countTimer) clearInterval(bar._countTimer);
    bar.classList.add("ai-chat__analyzing-bar--fade");
    var self = this;
    setTimeout(function(){
      if (bar.parentNode) bar.parentNode.removeChild(bar);
      self._analyzingBar = null;
    }, 300);
  };

  AiChatWidget.prototype.setComposerEnabled = function(enabled){
    var disabled = !enabled;

    // --- Button + icon swap ---------------------------------------------------
    if (this.sendBtnEl) {
      this.sendBtnEl.disabled = disabled;
      this.sendBtnEl.classList.toggle("is-busy", disabled);

      var idleIcon = this.sendBtnEl.querySelector(".ai-chat__send-icon--idle");
      var busyIcon = this.sendBtnEl.querySelector(".ai-chat__send-icon--busy");

      if (idleIcon && busyIcon) {
        idleIcon.hidden = disabled;   // hide arrow when busy
        busyIcon.hidden = !disabled;  // show clock when busy
      }
    }

    // --- Input enable/disable + placeholder swap ------------------------------
    if (this.inputEl) {
      // Cache the original placeholder once
      if (typeof this._idlePlaceholder === "undefined") {
        this._idlePlaceholder = this.inputEl.getAttribute("placeholder") || "";
      }

      this.inputEl.disabled = disabled;
      this.inputEl.setAttribute("placeholder", this._idlePlaceholder);
    }
  };

  AiChatWidget.prototype.setPromptVersionId = function(id){
    this.promptVersionId = null;
  };

