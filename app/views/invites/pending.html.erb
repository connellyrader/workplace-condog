<!-- app/views/invites/pending.html.erb -->
<div class="onboarding-bg"></div>

<div class="onboarding-content">
  <div class="info-card-header">
    You have pending workspace invites
  </div>

  <div class="info-card-content">
    <% @pending_invites.each do |invite| %>
      <% inviter = invite.invited_by %>
      <% inviter_name = (inviter&.respond_to?(:full_name) && inviter.full_name.present?) ? inviter.full_name : inviter&.email.to_s %>

      <div class="info-card-row" style="margin-bottom: 10px;">
        <div style="flex:1;">
          <div class="info-card-row">
            <div class="info-card-row-label">Workspace</div>
            <div class="info-card-row-value"><%= invite.workspace&.name.to_s %></div>
          </div>

          <div class="info-card-row">
            <div class="info-card-row-label">From</div>
            <div class="info-card-row-value"><%= inviter_name %></div>
          </div>

          <% if invite.role.present? %>
            <div class="info-card-row">
              <div class="info-card-row-label">Role</div>
              <div class="info-card-row-value"><%= invite.role.to_s.titleize %></div>
            </div>
          <% end %>

          <% if invite.expires_at.present? %>
            <div class="info-card-row">
              <div class="info-card-row-label">Expires</div>
              <div class="info-card-row-value"><%= invite.expires_at.in_time_zone.strftime("%B %-d, %Y at %-I:%M %p %Z") %></div>
            </div>
          <% end %>
        </div>

        <div class="info-card-actions" style="gap: 10px; align-items: center;">
          <%= button_to "Decline",
                        decline_pending_invite_path(invite),
                        method: :post,
                        class: "info-card-button-secondary",
                        form: { data: { turbo: false } } %>

          <%= button_to "Accept invite",
                        accept_pending_invite_path(invite),
                        method: :post,
                        class: "info-card-button-primary" %>
        </div>
      </div>

      <div style="height: 1px; background: rgba(148,163,184,0.25); margin: 14px 0;"></div>
    <% end %>

    <div class="info-card-actions">
      <%= link_to "Go to dashboard", dashboard_path, class: "info-card-button-secondary" %>
    </div>
  </div>
</div>
